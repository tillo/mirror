#!/bin/bash

(

# Wait for lock on $0.lock (fd 200) for 10 seconds
/usr/bin/flock -x -w 10 200 || exit 1

# Per https://tails.net/contribute/how/mirror/ the recommended cadence is
# every hour + a random 0..40 minute delay so the pool doesn't see all
# mirrors hit upstream at the same minute. Cron fires us hourly at :00.
/usr/bin/sleep $(/usr/bin/shuf --input-range=0-2400 --head-count=1)

RSYNC="/usr/bin/rsync"
# Match the rsync flags Tails publishes in its setup guide exactly.
OPTS="-rt --delete --timeout=300"

# rsync.tails.net is allow-listed; rsync.torproject.org::amnesia-archive is
# the same content (Tails infra is hosted by the Tor Project) and is open.
SRC1="rsync://rsync.torproject.org/amnesia-archive/"
SRC2="rsync://rsync.tails.net/amnesia-archive/"

DST="/srv/ftp/tails/"

echo "Started update at" `date` >> $0.log 2>&1
/usr/bin/logger -t sync-tails "Re-rsyncing the Tails tree"
${RSYNC} ${OPTS} ${SRC1} ${DST} >> $0.log 2>&1 || \
${RSYNC} ${OPTS} ${SRC2} ${DST} >> $0.log 2>&1

echo "End: "`date` >> $0.log 2>&1

) 200>$0.lock
